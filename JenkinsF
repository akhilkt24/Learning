pipeline {
    agent any

    environment {
        IMAGE_NAME     = "my-html-site"
        TEST_CONTAINER = "my-html-test"
        PROD_CONTAINER = "my-html-prod"
        TEST_PORT      = "8081"
        PROD_PORT      = "8080"
        EMAIL_TO       = "iamakhilkt@gmail.com"
    }

    triggers {
        cron('H 2 * * *')
    }

    stages {

        stage('Checkout Code') {
            steps {
                echo "Pulling source code from Git repository..."
                git branch: 'main', url: 'https://github.com/akhilkt24/Learning.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "Building Docker image..."
                sh '''
                docker build -t $IMAGE_NAME:$BUILD_NUMBER .
                docker tag $IMAGE_NAME:$BUILD_NUMBER $IMAGE_NAME:latest
                '''
            }
        }

        stage('Deploy to Test Environment') {
            steps {
                echo "Deploying container to TEST environment..."
                sh '''
                docker rm -f $TEST_CONTAINER || true
                docker run -d --name $TEST_CONTAINER -p $TEST_PORT:80 $IMAGE_NAME:$BUILD_NUMBER
                '''
            }
        }

        stage('Test Validation') {
            steps {
                echo "Running health check on TEST deployment..."

                script {

                    sleep 10

                    def status = sh(
                        script: "curl -s -o /dev/null -w '%{http_code}' http://localhost:$TEST_PORT",
                        returnStdout: true
                    ).trim()

                    echo "HTTP Response Code: ${status}"

                    if (status != "200") {
                        error "Application test failed! HTTP status: ${status}"
                    }

                    echo "Application test passed!"
                }
            }
        }

        stage('Manual Approval') {
            steps {
                input message: "Approve deployment to PRODUCTION?"
            }
        }

        stage('Deploy to Production') {
            steps {
                echo "Deploying container to PRODUCTION environment..."

                sh '''
                docker rm -f $PROD_CONTAINER || true
                docker run -d --name $PROD_CONTAINER -p $PROD_PORT:80 $IMAGE_NAME:$BUILD_NUMBER
                '''
            }
        }
    }

    post {

        success {
            echo "Pipeline completed successfully!"

            mail to: "${EMAIL_TO}",
            subject: "SUCCESS: ${JOB_NAME} Build #${BUILD_NUMBER}",
            body: """
Build SUCCESSFUL

Job Name: ${JOB_NAME}
Build Number: ${BUILD_NUMBER}
Docker Image: ${IMAGE_NAME}:${BUILD_NUMBER}

Production URL:
http://localhost:${PROD_PORT}

Build Details:
${BUILD_URL}
"""
        }

        failure {
            echo "Pipeline failed!"

            mail to: "${EMAIL_TO}",
            subject: "FAILED: ${JOB_NAME} Build #${BUILD_NUMBER}",
            body: """
Build FAILED

Job Name: ${JOB_NAME}
Build Number: ${BUILD_NUMBER}

Check logs here:
${BUILD_URL}
"""
        }
    }
}
