pipeline {
    agent any

    environment {
        IMAGE_NAME = "my-html-site"
        TEST_CONTAINER = "my-html-test"
        PROD_CONTAINER = "my-html-prod"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/akhilkt24/Learning.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t $IMAGE_NAME:$BUILD_NUMBER .'
            }
        }

        stage('Deploy Test') {
            steps {
                sh 'docker rm -f $TEST_CONTAINER || true'
                sh 'docker run -d --restart unless-stopped --name $TEST_CONTAINER -p 8081:80 $IMAGE_NAME:$BUILD_NUMBER'
            }
        }

        stage('Approval') {
            steps {
                input message: "Deploy to Production?"
            }
        }

        stage('Deploy Production') {
            steps {
                sh 'docker rm -f $PROD_CONTAINER || true'
                sh 'docker run -d --restart unless-stopped --name $PROD_CONTAINER -p 8080:80 $IMAGE_NAME:$BUILD_NUMBER'
            }
        }

    }
}
