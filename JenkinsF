pipeline {
    agent any

    environment {
        IMAGE_NAME = "my-html-site"
        TEST_CONTAINER = "my-html-test"
        PROD_CONTAINER = "my-html-prod"
        TEST_PORT = 8081
        PROD_PORT = 8080
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/akhilkt24/Learning.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t $IMAGE_NAME:$BUILD_NUMBER .'
            }
        }

        stage('Deploy Test') {
            steps {
                sh 'docker rm -f $TEST_CONTAINER || true'
                sh 'docker run -d --restart unless-stopped --name $TEST_CONTAINER -p $TEST_PORT:80 $IMAGE_NAME:$BUILD_NUMBER'
            }
        }

        stage('Test Validation') {
            steps {
                script {
                    // Basic health check
                    def status = sh(script: "curl -s -o /dev/null -w \"%{http_code}\" http://localhost:$TEST_PORT", returnStdout: true).trim()
                    if (status != "200") {
                        error "Test environment failed! HTTP status: $status"
                    }
                }
            }
        }

        stage('Approval') {
            steps {
                input message: "Deploy to Production?"
            }
        }

        stage('Deploy Production') {
            steps {
                sh 'docker rm -f $PROD_CONTAINER || true'
                sh 'docker run -d --restart unless-stopped --name $PROD_CONTAINER -p $PROD_PORT:80 $IMAGE_NAME:$BUILD_NUMBER'
            }
        }
    }
}
