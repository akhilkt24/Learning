pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/akhilkt24/Learning.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t my-html-site:latest .'
            }
        }

        stage('Deploy Test Environment') {
            steps {
                sh 'docker rm -f my-html-test || true'
                sh 'docker run -d --name my-html-test -p 8081:80 my-html-site:latest'
            }
        }

        stage('Test Application') {
            steps {
                sh 'sleep 5'
                sh 'curl -f http://localhost:8081'
            }
        }

        stage('Deploy Production') {
            steps {
                sh 'docker rm -f my-html-container || true'
                sh 'docker run -d --name my-html-container -p 8080:80 my-html-site:latest'
            }
        }
    }
}
