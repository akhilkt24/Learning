pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/akhilkt24/Learning.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t my-html-site:latest .'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f my-html-container || true'
            }
        }

        stage('Run New Container') {
            steps {
                sh 'docker run -d --name my-html-container -p 8080:80 my-html-site:latest'
            }
        }
    }
}
