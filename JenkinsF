pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/akhilkt24/Learning.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t my-html-site:$BUILD_NUMBER .'
            }
        }

        stage('Deploy Test') {
            steps {
                sh 'docker rm -f test-container || true'
                sh 'docker run -d --name test-container -p 8081:80 my-html-site:$BUILD_NUMBER'
            }
        }

        stage('Approval') {
            steps {
                input message: "Deploy to Production?"
            }
        }

        stage('Deploy Production') {
            steps {
                sh 'docker rm -f prod-container || true'
                sh 'docker run -d --name prod-container -p 8080:80 my-html-site:$BUILD_NUMBER'
            }
        }
    }
}
