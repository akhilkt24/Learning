pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/akhilkt24/Learning.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t my-html-site:latest .'
            }
        }

        stage('Deploy to Test') {
            steps {
                sh 'docker rm -f my-html-test || true'
                sh 'docker run -d --name my-html-test -p 8081:80 my-html-site:latest'
            }
        }

        stage('Approval for Production') {
            steps {
                input message: "Approve deployment to Production?", ok: "Deploy"
            }
        }

        stage('Deploy to Production') {
            steps {
                sh 'docker rm -f my-html-prod || true'
                sh 'docker run -d --name my-html-prod -p 8080:80 my-html-site:latest'
            }
        }

    }
}
