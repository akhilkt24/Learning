pipeline {
    agent any

    environment {
        IMAGE_NAME     = "my-html-site"
        TEST_CONTAINER = "my-html-test"
        PROD_CONTAINER = "my-html-prod"
        TEST_PORT      = 8081
        PROD_PORT      = 8080
    }

    triggers {
        // Schedule: every day at 2:00 AM (example)
        cron('H 2 * * *')
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/akhilkt24/Learning.git'
            }
        }

        stage('Build') {
            steps {
                sh """
                docker build -t $IMAGE_NAME:$BUILD_NUMBER .
                docker tag $IMAGE_NAME:$BUILD_NUMBER $IMAGE_NAME:latest
                """
            }
        }

        stage('Deploy Test') {
            steps {
                sh """
                docker rm -f $TEST_CONTAINER || true
                docker run -d --restart unless-stopped --name $TEST_CONTAINER -p $TEST_PORT:80 $IMAGE_NAME:$BUILD_NUMBER
                """
            }
        }

        stage('Test Validation') {
            steps {
                script {
                    // Retry 5 times in 3-second intervals
                    def status = sh(script: """
                    for i in {1..5}; do
                        code=\$(curl -s -o /dev/null -w "%{http_code}" http://localhost:$TEST_PORT)
                        if [ "\$code" == "200" ]; then exit 0; fi
                        sleep 3
                    done
                    exit 1
                    """, returnStatus: true)
                    if (status != 0) {
                        error "Test environment failed!"
                    }
                }
            }
        }

        stage('Approval') {
            steps {
                input message: "Deploy to Production?"
            }
        }

        stage('Deploy Production') {
            steps {
                sh """
                docker rm -f $PROD_CONTAINER || true
                docker run -d --restart unless-stopped --name $PROD_CONTAINER -p $PROD_PORT:80 $IMAGE_NAME:$BUILD_NUMBER
                """
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed! Check logs for details."
        }
        success {
            echo "Pipeline completed successfully!"
        }
    }
}
